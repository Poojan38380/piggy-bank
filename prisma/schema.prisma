generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

model Expense {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  amount         Int      // Stored in paise (integer)
  category       String
  description    String
  date           DateTime
  idempotencyKey String   @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([date])
}
