# Environment Variables — PiggyBank by Fenmo
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────
# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGO_URI=

# ── Auth (Phase 2 — NextAuth v5 / Google OAuth) ───────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=

# The public URL of your app (no trailing slash)
# Local dev: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL=http://localhost:3000

# Google OAuth credentials — get from console.cloud.google.com
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=